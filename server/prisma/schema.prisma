model Student {
  id       String  @id
  name     String
  email    String  @unique
  avatar   String?
  password String
  group_id String

  // group Group @relation(fields: [group_id], references: [id])
}

model Faculty {
  id           String     @id
  name         String
  email        String  @unique
  password     String  @unique
  phone_number String  @unique
  avatar       String?

  // faculty_subjects Faculty_Subject[]
  // timetables       Timetable[]
}

